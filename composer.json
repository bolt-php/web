{
    "name": "bolt-php/web",
    "type": "framework",
    "keywords": [
        "php",
        "framework"
    ],
    "description": "Web application / toolset for Tiny framework",
    "license": "MIT",
    "authors": [
        {
            "name": "Faheem Anis",
            "email": "faheem@cartzlink.com",
            "homepage": "https://faheemanis.rf.gd/",
            "role": "Developer"
        }
    ],
    "require": {
        "php": ">=8.0",
        "bolt-php/core": ">=1.2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5"
    },
    "autoload": {
        "psr-4": {
            "framework\\web\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "framework\\web\\tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpdbg -qrr vendor/bin/phpunit --coverage-html .coverage"
    }
}
